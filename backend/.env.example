# ── App ────────────────────────────────────────────────────────
APP_NAME=EduEval AI Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001

# ── Database (MySQL required, no SQLite fallback) ────────────────
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/edueval_ai?charset=utf8mb4
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── Storage ──────────────────────────────────────────────────────
STORAGE_ROOT=./storage
PREVIEW_CONVERTER_PATH=soffice

# ── AI Model (DeepSeek / OpenAI-compatible) ──────────────────────
# Used for: blog classification, document import parsing
MODEL_PROVIDER=openai-compatible
MODEL_NAME=deepseek-chat
MODEL_BASE_URL=
MODEL_API_KEY=

# ── Blog Crawler (CSDN via Playwright CDP) ────────────────────────
# Enable after starting Chrome with:
#   chrome.exe --remote-debugging-port=9222 --user-data-dir=./storage/browser_profile
BLOG_CRAWLER_ENABLED=false
BLOG_CRAWLER_SOURCE=csdn
BLOG_CDP_URL=http://127.0.0.1:9222
BLOG_LAUNCH_CHROME=false
BLOG_CHROME_EXE=
BLOG_PROFILE_DIR=./storage/browser_profile
BLOG_MAX_PAGES=100
BLOG_MAX_POSTS_PER_SOURCE=500
BLOG_MIN_DELAY_SECONDS=2.0
BLOG_MAX_DELAY_SECONDS=5.0
BLOG_NAVIGATION_TIMEOUT_MS=45000
BLOG_PAGE_LOAD_WAIT_MS=2000

# ── Repo Sync (Gitee) ────────────────────────────────────────────
REPO_AUTO_SYNC_ENABLED=true
REPO_AUTO_SYNC_POLL_MINUTES=15
REPO_AUTO_SYNC_WEEKDAY=1
REPO_AUTO_SYNC_HOUR=3
REPO_AUTO_SYNC_MAX_PAGES=3
